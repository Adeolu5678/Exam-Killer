# ===========================================
# Exam-Killer Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ===========================================
# Firebase Client Configuration
# ===========================================
# Get these from Firebase Console > Project Settings > General > Your apps
# These are safe to expose to the browser (NEXT_PUBLIC_ prefix)

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ===========================================
# Firebase Admin Configuration
# ===========================================
# Option 1: Use the full service account JSON (recommended)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content as a single line string
FIREBASE_SERVICE_ACCOUNT_KEY=

# Option 2: Use individual environment variables
# Required if FIREBASE_SERVICE_ACCOUNT_KEY is not provided
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ===========================================
# OpenAI Configuration
# ===========================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# Paystack Configuration
# ===========================================
# Get these from Paystack Dashboard > Settings > API Keys & Webhooks
# Public key is safe to expose (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Secret key - NEVER expose this to the browser
PAYSTACK_SECRET_KEY=

# Paystack Webhook - Get from Paystack Dashboard > Settings > Webhooks
# This is used to verify webhook requests from Paystack
PAYSTACK_WEBHOOK_SECRET=

# ===========================================
# Pinecone Configuration (Optional - for vector storage)
# ===========================================
# Get these from Pinecone Console > API Keys
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=

# ===========================================
# Application Configuration
# ===========================================
# The base URL of your application
# Development: http://localhost:3000
# Production: your production domain
NEXT_PUBLIC_APP_URL=http://localhost:3000
